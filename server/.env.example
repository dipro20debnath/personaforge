# PersonaForge AI Integration - Environment Configuration

# Copy this file to .env.local in the server directory and fill in with your values

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# Database Configuration
DATABASE_URL=personaforge

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production

# AI Integration - OpenAI Setup
# Get your API key from: https://platform.openai.com/api-keys
AI_API_KEY=sk-demo-key

# OpenAI API Endpoint (usually the default)
AI_API_URL=https://api.openai.com/v1

# OpenAI Model to use
AI_MODEL=gpt-4-turbo-preview

# Debugging and Logging
DEBUG_SECURITY=false
DEBUG_AI=false

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting Configuration
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=5
RATE_LIMIT_STRICT=20
RATE_LIMIT_AI=10

# Email Configuration (Optional - for future notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# WebSocket Configuration (Optional - for real-time features)
# WEBSOCKET_ENABLED=true

# Monitoring and Analytics (Optional)
# SENTRY_DSN=your-sentry-dsn

# Feature Flags
FEATURE_AI_ENABLED=true
FEATURE_WEBSOCKET_ENABLED=false
FEATURE_ADVANCED_ANALYTICS=false
